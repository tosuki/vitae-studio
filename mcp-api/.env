PORT=3001
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Autenticação do Gemini
# 1. Modo OAuth2 Pessoal / GCP Application Default Credentials (ADC) - RECOMENDADO PARA SUA CONTA PESSOAL COM PLANO PRO
# Para utilizar a sua conta do Google autenticada localmente (como no gemini-cli):
# Rode no seu terminal: gcloud auth application-default login
# O SDK do Node detectará automaticamente o arquivo JSON gerado em ~/.config/gcloud/
# Se usar este modo, mantenha as chaves abaixo desativadas/vazias ou configure apenas o ID do projeto se necessário.
# GOOGLE_GENAI_USE_ENTERPRISE=false
# GOOGLE_CLOUD_PROJECT=seu-projeto-gcp-id

# 2. Modo API Key (Alternativo)
# Se preferir usar uma chave de API do Google AI Studio:
# GEMINI_API_KEY=sua_chave_de_api_aqui
