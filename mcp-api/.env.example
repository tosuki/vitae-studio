PORT=3001
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Autenticação do Gemini
# 1. Modo OAuth2 / GCP Application Default Credentials (ADC)
# Para utilizar a sua conta do Google autenticada localmente:
# Rode no seu terminal: gcloud auth application-default login
# O SDK do Node detectará o token de acesso automaticamente.
# GOOGLE_GENAI_USE_ENTERPRISE=false
# GOOGLE_CLOUD_PROJECT=seu-projeto-gcp-id

# 2. Modo API Key (Alternativo)
# GEMINI_API_KEY=sua_chave_de_api_aqui
